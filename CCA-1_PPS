import random

# Step 1: Predefined list of words
words = ["apple", "banana", "grape", "orange", "mango"]

# Step 2: Randomly choose a word
word = random.choice(words)

# Step 3: Create a list of underscores
guessed_word = ["_"] * len(word)

# Step 4: Track guessed letters and attempts
guessed_letters = []
attempts = 3  # number of wrong guesses allowed

print("Welcome to Hangman!")

# Step 5: Game loop
while attempts > 0 and "_" in guessed_word:
    print("\nWord:", " ".join(guessed_word))
    print("Attempts left:", attempts)

    guess = input("Enter a letter: ").lower()

    # Check if already guessed
    if guess in guessed_letters:
        print("You already guessed that letter.")
        continue

    guessed_letters.append(guess)

    # Check if guess is correct
    if guess in word:
        print("Correct guess!")
        for i in range(len(word)):
            if word[i] == guess:
                guessed_word[i] = guess
    else:
        print("Wrong guess!")
        attempts -= 1

# Step 6: Result
if "_" not in guessed_word:
    print("\nCongratulations! You guessed the word:", word)
else:
    print("\nGame Over! The word was:", word)
